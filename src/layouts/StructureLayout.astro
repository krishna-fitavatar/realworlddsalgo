---
// TEMPLATE LAYER — the page shell. Holds no data of its own; everything comes
// in via props or <slot/>.
interface Props {
  title: string;
  summary?: string;
}
const { title, summary } = Astro.props;
const tagline = 'Real-world uses of data structures & algorithms';
// Serving subpath; strip any trailing slash so links join cleanly as `${base}/...`
// (BASE_URL may or may not carry a trailing slash depending on config).
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · realworlddsalgo</title>
    {summary && <meta name="description" content={summary} />}
  </head>
  <body>
    <header class="site-header">
      <a href={`${base}/`} class="brand">realworlddsalgo</a>
      <span class="tagline">{tagline}</span>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Open source · static · hosted on GitHub Pages</p>
    </footer>

    <style is:global>
      :root {
        --fg: #111827;
        --muted: #6b7280;
        --border: #e5e7eb;
        --accent: #2563eb;
        --max: 760px;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        color: var(--fg);
        line-height: 1.6;
      }
      main { max-width: var(--max); margin: 0 auto; padding: 1.5rem 1.25rem 3rem; }
      .site-header {
        display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap;
        max-width: var(--max); margin: 0 auto; padding: 1.25rem;
        border-bottom: 1px solid var(--border);
      }
      .brand { font-weight: 700; font-size: 1.1rem; text-decoration: none; color: var(--fg); }
      .tagline { color: var(--muted); font-size: 0.9rem; }
      .site-footer { max-width: var(--max); margin: 0 auto; padding: 1.25rem; color: var(--muted); font-size: 0.85rem; border-top: 1px solid var(--border); }
      a { color: var(--accent); }
      h1 { margin-bottom: 0.25rem; }
      .category-tag {
        display: inline-block; font-size: 0.75rem; text-transform: uppercase;
        letter-spacing: 0.04em; color: var(--muted); border: 1px solid var(--border);
        border-radius: 999px; padding: 0.1rem 0.6rem;
      }
      table.complexity { border-collapse: collapse; margin: 1rem 0; }
      table.complexity th, table.complexity td { border: 1px solid var(--border); padding: 0.35rem 0.7rem; text-align: left; font-size: 0.9rem; }
      section { margin-top: 2rem; }
      section > h2 { border-bottom: 1px solid var(--border); padding-bottom: 0.3rem; }

      /* viz (island renders outside Astro's scoped styles → global) */
      /* <astro-island> defaults to display:inline and collapses to zero height,
         which means client:visible's IntersectionObserver never fires and the
         viz never hydrates. Force block so it has layout height. */
      astro-island { display: block; }
      .viz { margin: 0; border: 1px solid var(--border); border-radius: 10px; padding: 1rem; }
      .viz-stage { display: flex; justify-content: center; }
      .viz-stage svg { max-width: 100%; height: auto; }
      .viz-empty { color: var(--muted); text-align: center; padding: 2rem; }
      .viz-note { font-size: 0.9rem; color: var(--fg); margin: 0.75rem 0; min-height: 2.5em; }
      .viz-step { font-weight: 600; color: var(--muted); }
      .viz-controls { display: flex; gap: 0.5rem; }
      .viz-controls button {
        font: inherit; padding: 0.35rem 0.8rem; border: 1px solid var(--border);
        background: #f9fafb; border-radius: 6px; cursor: pointer;
      }
      .viz-controls button:disabled { opacity: 0.45; cursor: default; }

      .refs { list-style: none; padding: 0; }
      .refs li { padding: 0.5rem 0; border-bottom: 1px solid var(--border); }
      .refs .repo { font-weight: 600; }
      .refs .desc { color: var(--fg); }
      .refs .path { color: var(--muted); font-size: 0.85rem; }
    </style>
  </body>
</html>
